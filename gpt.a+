‚çù === Training Corpus (8 sequences, for reference) ===
‚çù Sequences: [0,1,2,3] [1,2,3,4] [2,3,4,5] [3,4,5,6] [4,5,6,7] [5,6,7,0] [6,7,0,1] [7,0,1,2]
‚çù Targets:    [1,2,3,4] [2,3,4,5] [3,4,5,6] [4,5,6,7] [5,6,7,0] [6,7,0,1] [7,0,1,2] [0,1,2,3]

‚çù === Forward Pass: One Transformer Block ===
‚çù gpt_forward tokens -> logits (seq x vocab) using stored weights
gpt_forward{tokens}: {

  ‚çù 1. Embedding lookup + position encoding
  xemb‚Üêseq dm ‚ç¥ 0
  pos‚Üê0
  while (pos<seq) {
    idx‚Üêtokens[pos]
    j‚Üê0
    while (j<dm) {
      xemb[pos√ódm+j]‚ÜêE[idx√ódm+j] + P[pos√ódm+j]
      j‚Üêj+1
    }
    pos‚Üêpos+1
  }

  ‚çù 2. Compute Q, K, V = xemb @ Wq, Wk, Wv
  Q‚Üêseq dm ‚ç¥ 0
  K‚Üêseq dm ‚ç¥ 0
  V‚Üêseq dm ‚ç¥ 0
  ‚çù Q = xemb +.√ó Wq using manual loops (inner product not available for all impls)
  i‚Üê0
  while (i<seq) {
    j‚Üê0
    while (j<dm) {
      s‚Üê0.0
      k‚Üê0
      while (k<dm) {
        s‚Üês + xemb[i√ódm+k] √ó Wq[k√ódm+j]
        k‚Üêk+1
      }
      Q[i√ódm+j]‚Üês
      s‚Üê0.0
      k‚Üê0
      while (k<dm) {
        s‚Üês + xemb[i√ódm+k] √ó Wk[k√ódm+j]
        k‚Üêk+1
      }
      K[i√ódm+j]‚Üês
      s‚Üê0.0
      k‚Üê0
      while (k<dm) {
        s‚Üês + xemb[i√ódm+k] √ó Wv[k√ódm+j]
        k‚Üêk+1
      }
      V[i√ódm+j]‚Üês
      j‚Üêj+1
    }
    i‚Üêi+1
  }

  ‚çù 3. Multi-head attention (4 heads, dk=2) + concatenate + project
  concat‚Üêseq dm ‚ç¥ 0
  h‚Üê0
  while (h<nheads) {
    hoff‚Üêh√ódk

    ‚çù Compute attention scores for head h: scores = Q_h @ K_h^T * scale
    scores‚Üêseq seq ‚ç¥ 0
    qi‚Üê0
    while (qi<seq) {
      kj‚Üê0
      while (kj<seq) {
        dot‚Üê0.0
        d‚Üê0
        while (d<dk) {
          dot‚Üêdot + Q[qi√ódm+hoff+d] √ó K[kj√ódm+hoff+d]
          d‚Üêd+1
        }
        scores[qi√óseq+kj]‚Üêdot √ó scale
        kj‚Üêkj+1
      }
      qi‚Üêqi+1
    }

    ‚çù Softmax row-wise on scores -> attn_weights
    attn‚Üêseq seq ‚ç¥ 0
    qi‚Üê0
    while (qi<seq) {
      ‚çù Extract row and compute softmax
      row‚Üêseq ‚ç¥ 0
      kj‚Üê0
      while (kj<seq) {
        row[kj]‚Üêscores[qi√óseq+kj]
        kj‚Üêkj+1
      }
      srow‚Üêsoftmax{row;seq}
      kj‚Üê0
      while (kj<seq) {
        attn[qi√óseq+kj]‚Üêsrow[kj]
        kj‚Üêkj+1
      }
      qi‚Üêqi+1
    }

    ‚çù Weighted sum: context_h = attn @ V_h
    ctx‚Üêseq dk ‚ç¥ 0
    qi‚Üê0
    while (qi<seq) {
      dj‚Üê0
      while (dj<dk) {
        s‚Üê0.0
        kk‚Üê0
        while (kk<seq) {
          s‚Üês + attn[qi√óseq+kk] √ó V[kk√ódm+hoff+dj]
          kk‚Üêkk+1
        }
        ctx[qi√ódk+dj]‚Üês
        dj‚Üêdj+1
      }
      qi‚Üêqi+1
    }

    ‚çù Place context_h into concat at head position
    qi‚Üê0
    while (qi<seq) {
      dj‚Üê0
      while (dj<dk) {
        concat[qi√ódm+hoff+dj]‚Üêctx[qi√ódk+dj]
        dj‚Üêdj+1
      }
      qi‚Üêqi+1
    }
    h‚Üêh+1
  }

  ‚çù 4. Output projection: attn_out = concat @ Wo
  attn_out‚Üêseq dm ‚ç¥ 0
  i‚Üê0
  while (i<seq) {
    j‚Üê0
    while (j<dm) {
      s‚Üê0.0
      k‚Üê0
      while (k<dm) {
        s‚Üês + concat[i√ódm+k] √ó Wo[k√ódm+j]
        k‚Üêk+1
      }
      attn_out[i√ódm+j]‚Üês
      j‚Üêj+1
    }
    i‚Üêi+1
  }

  ‚çù 5. Residual connection + Layer Norm 1
  x1ln‚Üêseq dm ‚ç¥ 0
  i‚Üê0
  while (i<seq) {
    ‚çù Compute mean
    m‚Üê0.0
    j‚Üê0
    while (j<dm) {
      m‚Üêm + xemb[i√ódm+j] + attn_out[i√ódm+j]
      j‚Üêj+1
    }
    m‚Üêm√∑dm
    ‚çù Compute variance
    v‚Üê0.0
    j‚Üê0
    while (j<dm) {
      t‚Üêxemb[i√ódm+j] + attn_out[i√ódm+j] - m
      v‚Üêv + t√ót
      j‚Üêj+1
    }
    v‚Üêv√∑dm
    ‚çù Normalize and scale: y = gamma*(x-mean)/(var+eps) + beta
    eps‚Üê0.00001
    j‚Üê0
    while (j<dm) {
      t‚Üêxemb[i√ódm+j] + attn_out[i√ódm+j]
      x1ln[i√ódm+j]‚Üêgamma1[j] √ó (t-m) √∑ (v+eps) + beta1[j]
      j‚Üêj+1
    }
    i‚Üêi+1
  }

  ‚çù 6. Feed-forward: h_ffn = sigmoid(x1ln @ W1), ffn_out = h_ffn @ W2
  hffn‚Üêseq dff ‚ç¥ 0
  i‚Üê0
  while (i<seq) {
    j‚Üê0
    while (j<dff) {
      s‚Üê0.0
      k‚Üê0
      while (k<dm) {
        s‚Üês + x1ln[i√ódm+k] √ó W1[k√ódff+j]
        k‚Üêk+1
      }
      ‚çù sigmoid
      hffn[i√ódff+j]‚Üê1√∑1+*-s
      j‚Üêj+1
    }
    i‚Üêi+1
  }

  ffn_out‚Üêseq dm ‚ç¥ 0
  i‚Üê0
  while (i<seq) {
    j‚Üê0
    while (j<dm) {
      s‚Üê0.0
      k‚Üê0
      while (k<dff) {
        s‚Üês + hffn[i√ódff+k] √ó W2[k√ódm+j]
        k‚Üêk+1
      }
      ffn_out[i√ódm+j]‚Üês
      j‚Üêj+1
    }
    i‚Üêi+1
  }

  ‚çù 7. Residual connection + Layer Norm 2
  x2ln‚Üêseq dm ‚ç¥ 0
  i‚Üê0
  while (i<seq) {
    m‚Üê0.0
    j‚Üê0
    while (j<dm) {
      m‚Üêm + x1ln[i√ódm+j] + ffn_out[i√ódm+j]
      j‚Üêj+1
    }
    m‚Üêm√∑dm
    v‚Üê0.0
    j‚Üê0
    while (j<dm) {
      t‚Üêx1ln[i√ódm+j] + ffn_out[i√ódm+j] - m
      v‚Üêv + t√ót
      j‚Üêj+1
    }
    v‚Üêv√∑dm
    eps‚Üê0.00001
    j‚Üê0
    while (j<dm) {
      t‚Üêx1ln[i√ódm+j] + ffn_out[i√ódm+j]
      x2ln[i√ódm+j]‚Üêgamma2[j] √ó (t-m) √∑ (v+eps) + beta2[j]
      j‚Üêj+1
    }
    i‚Üêi+1
  }

  ‚çù 8. Output projection to vocab: logits = x2ln @ E^T
  logits‚Üêseq vocab ‚ç¥ 0
  i‚Üê0
  while (i<seq) {
    t‚Üê0
    while (t<vocab) {
      s‚Üê0.0
      k‚Üê0
      while (k<dm) {
        s‚Üês + x2ln[i√ódm+k] √ó E[t√ódm+k]
        k‚Üêk+1
      }
      logits[i√óvocab+t]‚Üês
      t‚Üêt+1
    }
    i‚Üêi+1
  }

  logits
}

‚çù === Self-Tests ===

‚çù Test 1: softmax integrity
tsv‚Üêsoftmax{1 2 3;3}
tss‚Üêtsv[0]+tsv[1]+tsv[2]
if ((tss>0.99)√ó(tss<1.01)) { ‚éï"[PASS] softmax sums to ~1" } else { ‚éï"[FAIL] softmax" }

‚çù Test 2: Forward pass on prompt [0,1,2,3]
prompt‚Üê4 ‚ç¥ 0 1 2 3
result‚Üêgpt_forward{prompt}

‚çù Test 3: Verify output shape is 4x8
rsh‚Üê‚ç¥ result
if (rsh[0]=4) { ‚éï"[PASS] output has 4 rows" } else { ‚éï"[FAIL] rows" }
if (rsh[1]=8) { ‚éï"[PASS] output has 8 cols" } else { ‚éï"[FAIL] cols" }

‚çù Test 4: Verify logits are finite (not inf/nan)
ok‚Üê1
i‚Üê0
while (i<4) {
  j‚Üê0
  while (j<8) {
    v‚Üêresult[i√ó8+j]
    if (v<0-1e6) { ok‚Üê0 }
    if (v>1e6) { ok‚Üê0 }
    j‚Üêj+1
  }
  i‚Üêi+1
}
if (ok=1) { ‚éï"[PASS] logits in finite range" } else { ‚éï"[FAIL] logits range" }

‚çù Test 5: Last position (token 3) should predict token 4 as most likely
last‚Üê4√ó8
pred‚Üê0-1e9
pred_idx‚Üê0
j‚Üê0
while (j<8) {
  if (result[last+j]>pred) {
    pred‚Üêresult[last+j]
    pred_idx‚Üêj
  }
  j‚Üêj+1
}
‚éï"Predicted next token:"
‚éï pred_idx
if (pred_idx=4) {
  ‚éï"[PASS] GPT correctly predicts token 4 after [0,1,2,3]"
}
if (pred_idx=4) { ok_pred‚Üê1 } else { ok_pred‚Üê0 }
if (ok_pred=0) {
  ‚éï"[INFO] GPT predicts token different from expected 4"
  ‚éï"  (This may be OK with random initialization + limited training)"
}

‚çù Test 6: Softmax distribution over vocab at last position
lrow‚Üê8 ‚ç¥ 0
j‚Üê0
while (j<8) {
  lrow[j]‚Üêresult[last+j]
  j‚Üêj+1
}
