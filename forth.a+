  f_push{42}
  r14¹f_top{}
  f_dot{}
  if (r14=42) {
    š "[PASS] forth: IF/THEN true branch works"
  } else {
    š "[FAIL] forth: IF/THEN wrong result"
  }
} else {
  f_push{99}
  š "[FAIL] forth: IF condition should be true"
}

