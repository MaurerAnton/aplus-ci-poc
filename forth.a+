Ń forth.a+ ▀▀▀ Forth Interpreter in A+ ▀▀▀
Ń
Ń Features: data stack, return stack, dictionary, colon defs,
Ń IF/ELSE/THEN, DO/LOOP, core words DUP DROP SWAP OVER + - * / = < > . EMIT CR
Ń
ds¹100╬0
dsp¹0

f_push{n}: {
  ds[dsp]¹n
  dsp¹dsp+1
}

f_pop{}: {
  if (dsp>0) {
    dsp¹dsp-1
    ds[dsp]
  } else {
    0
  }
}

f_dup{}: {
  if (dsp>0) {
    ds[dsp]¹ds[dsp-1]
    dsp¹dsp+1
  }
}

f_drop{}: {
  if (dsp>0) { dsp¹dsp-1 }
}

f_swap{}: {
  if (dsp>=2) {
    tmp¹ds[dsp-1]
    ds[dsp-1]¹ds[dsp-2]
    ds[dsp-2]¹tmp
  }
}

f_over{}: {
  if (dsp>=2) {
    ds[dsp]¹ds[dsp-2]
    dsp¹dsp+1
  }
}

f_add{}: {
  if (dsp>=2) { dsp¹dsp-1; ds[dsp-1]¹ds[dsp-1]+ds[dsp] }
}

f_sub{}: {
  if (dsp>=2) { dsp¹dsp-1; ds[dsp-1]¹ds[dsp-1]-ds[dsp] }
}

f_mul{}: {
  if (dsp>=2) { dsp¹dsp-1; ds[dsp-1]¹ds[dsp-1]*ds[dsp] }
}

f_div{}: {
  if (dsp>=2) {
    dsp¹dsp-1
    if (ds[dsp]!=0) { ds[dsp-1]¹ds[dsp-1]▀ds[dsp] }
    else { ds[dsp-1]¹0 }
  }
}

f_eq{}: {
  if (dsp>=2) {
    dsp¹dsp-1
    if (ds[dsp-1]=ds[dsp]) { ds[dsp-1]¹1 }
    else { ds[dsp-1]¹0 }
  }
}

f_lt{}: {
  if (dsp>=2) {
    dsp¹dsp-1
    if (ds[dsp-1]<ds[dsp]) { ds[dsp-1]¹1 }
    else { ds[dsp-1]¹0 }
  }
}

f_gt{}: {
  if (dsp>=2) {
    dsp¹dsp-1
    if (ds[dsp-1]>ds[dsp]) { ds[dsp-1]¹1 }
    else { ds[dsp-1]¹0 }
  }
}

f_dot{}: {
  if (dsp>0) { dsp¹dsp-1; š ds[dsp] }
}

f_emit{}: {
  if (dsp>0) { dsp¹dsp-1; š ds[dsp] }
}

f_cr{}: {
  š ""
}

f_reset{}: {
  dsp¹0
}

f_top{}: {
  if (dsp>0) { ds[dsp-1] }
  else { -99999 }
}

š "=== Forth Self-Tests ==="

š "-- Test 1: 2 3 + . (expect 5) --"
f_reset{}
f_push{2}
f_push{3}
f_add{}
r1¹f_top{}
š "Result: "
f_dot{}
if (r1=5) {
  š "[PASS] forth: 2 3 + . = 5"
} else {
  š "[FAIL] forth: 2 3 + . expected 5"
}

