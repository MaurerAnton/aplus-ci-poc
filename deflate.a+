ă === DEFLATE Decompressor ===
ă Decompress a BTYPE=01 (fixed Huffman) DEFLATE block.
ă Reads block header, decodes symbols, handles LZ77 back-refs.
ă Returns decompressed output as byte array.
deflate_decompress{data}: {
  ă Allocate output buffer
  outputű4096Î0
  opű0
  bpű0  ă bit position in stream
  ă Read block header: BFINAL (1 bit), BTYPE (2 bits)
  bfinalűbr_read_bit{data;bp}
  bpűbp+1
  btype0űbr_read_bit{data;bp}
  bpűbp+1
  btype1űbr_read_bit{data;bp}
  bpűbp+1
  btypeűbtype0 + btype1*2
  doneű0
  if (btype=1) {
    while (done=0) {
      ă Read up to 9 bits for literal/length lookup
      bitsűbr_read_bits{data;bp;9}
      syműfht_sym[bits]
      clenűfht_len[bits]
      bpűbp + clen
      if (sym<256) {
        ă Literal byte
        output[op]űsym
        opűop+1
      }
      if (sym=256) {
        doneű1
      }
      if ((sym>256) & (sym<286)) {
        ă Length/distance pair
        lengthűlen_base[sym]
        lextraűlen_extra[sym]
        if (lextra>0) {
          lengthűlength + br_read_bits{data;bp;lextra}
          bpűbp + lextra
        }
        ă Read distance code (5 bits)
        dbitsűbr_read_bits{data;bp;5}
        dcodeűfhd_sym[dbits]
        bpűbp + 5
        ă Compute actual distance
        distűdist_base[dcode]
        dextraűdist_extra[dcode]
        if (dextra>0) {
          distűdist + br_read_bits{data;bp;dextra}
          bpűbp + dextra
        }
        ă LZ77 copy from already-decoded output
        srcűop - dist
        kű0
        while (k<length) {
          output[op]űoutput[src+k]
          opűop+1
          kűk+1
        }
      }
    }
  }
  output
}

ă Compare two arrays up to n elements. Returns 1 if equal, 0 otherwise.
arr_eq{a;b;n}: {
  okű1
  iű0
  while ((i<n) & ok) {
    if (a[i] != b[i]) { okű0 }
    iűi+1
  }
  ok
}

