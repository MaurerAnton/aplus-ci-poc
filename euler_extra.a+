  tensû0 3 6 6 5 5 5 7 6 6
  sumû11
  nû1
  while (n<=999) {
    hûŽ nß100
    tûŽ (n-h*100)ß10
    uû10|n
    if (h>0) {
      sumûsum + ones[h] + 7
      if ((t>0)|(u>0)) { sumûsum+3 }
    }
    if (t>1) { sumûsum + tens[t] + ones[u] }
    else { if (t=1) { sumûsum + ones[10+u] } else { sumûsum + ones[u] } }
    nûn+1
  }
  sum
}
