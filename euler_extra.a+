ã=== #17: Number letter counts ===

ãSum of letters for numbers 1..1000 = 21124

ãones = 3,3,5,4,4,3,5,5,4,3,6,6,8,8,7,7,9,8,8,6

ãtens = 6,6,5,5,5,7,6,6,7

p17{}:
