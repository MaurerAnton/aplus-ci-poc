ã=== #19: Counting Sundays ===

ãSundays on 1st of month, 1901-2000 = 171

p19{}:
{
  dowû2
  countû0
  yû1901
  while (y<=2000) {
    mû1
    while (m<=12) {
      if (dow=0) { countûcount+1 }
      if (m=2) {
        leapû0
        if (0=4|y) { leapû1 }
        if (0=100|y) { leapû0 }
        if (0=400|y) { leapû1 }
        dowûdow+28+leap
      } else {
        if ((m=4)|(m=6)|(m=9)|(m=11)) { dowûdow+30 }
        else { dowûdow+31 }
      }
      dowû7|dow
      mûm+1
    }
    yûy+1
  }
  count
}
