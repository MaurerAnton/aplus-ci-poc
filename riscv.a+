ïŋ― --- Execute program (~15 steps) ---
stepsïŋ―0
while (steps < 15) {
  step{}
  stepsïŋ―steps+1
}

ïŋ― --- Print register values ---
ïŋ― "RISC-V Register values after execution:"
riïŋ―0
while (ri < 16) {
  if (regs[ri] != 0) {
    ïŋ― "  x" + ri + " = " + regs[ri]
  }
  riïŋ―ri+1
}

