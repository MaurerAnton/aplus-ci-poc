if (regs[5] = 30) {
  ïŋ― "riscv: [PASS] ADD x5=x6+x7: 10+20=30"
} else {
  ïŋ― "riscv: [FAIL] ADD expected 30, got " + regs[5]
}

ïŋ― --- Test 3: Branch taken correctly ---
ïŋ― Test BEQ: if x8==x9 skip next, where x8=5, x9=5
regs[8]ïŋ―5
regs[9]ïŋ―5
ïŋ― BEQ x8, x9, +8 -> encode: b_type(8, 9, 8, 0, 0x63)
ïŋ― = 0x00940463
mem[104]ïŋ―0x63
mem[105]ïŋ―0x04
mem[106]ïŋ―0x94
mem[107]ïŋ―0x00
pcïŋ―104
