ïŋ― --- Test 1: x0 is always 0 ---
if (regs[0] = 0) {
  ïŋ― "riscv: [PASS] x0 is always 0"
} else {
  ïŋ― "riscv: [FAIL] x0 is " + regs[0]
}

ïŋ― --- Test 2: ADD instruction result ---
ïŋ― Run a quick ADD test: x5 = x6 + x7 where x6=10, x7=20
regs[6]ïŋ―10
regs[7]ïŋ―20
ïŋ― ADD x5, x6, x7 = 0x00730333... no: R-type: f7=0, rs2=x7=7, rs1=x6=6, f3=0, rd=x5=5, op=0x33
ïŋ― = 0x007302B3
mem[100]ïŋ―0xB3
mem[101]ïŋ―0x02
mem[102]ïŋ―0x73
mem[103]ïŋ―0x00
pcïŋ―100
