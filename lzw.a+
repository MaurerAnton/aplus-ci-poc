ă === SELF-TESTS ===
ă ========================

ă Allocate dictionary arrays
dict_prefixűMAX_DICTÎ0
dict_byteűMAX_DICTÎ0
dict_sizeű0

ă --- Test 1: Compress 'TOBEORNOTTOBEORTOBEORNOT' ---
ă ASCII: T=84 O=79 B=66 E=69 R=82 N=78
test1ű84 79 66 69 79 82 78 79 84 84 79 66 69 79 82 84 79 66 69 79 82 78 79 84
comp1űlzw_compress{test1}
  Ő \"lzw: compressed TOBEORNOTTOBEORTOBEORNOT codes:\"
  Ő comp1

ă Count codes (excluding sentinel -1)
code_countű0
ci1ű0
while (comp1[ci1]>=0) {
  code_countűcode_count+1
  ci1űci1+1
}
  Ő \"lzw: code count:\"
  Ő code_count
ă Expected: fewer than 24 (the input length) due to compression
if (code_count < 24) {
  Ő \"lzw: [PASS] compression achieved (fewer codes than input bytes)\"
} else {
  Ő \"lzw: [FAIL] no compression\"
}

ă --- Test 2: Decompress back to original ---
decomp1űlzw_decompress{comp1}
dec_okű1
di1ű0
while ((test1[di1]>=0) | (decomp1[di1]>=0)) {
  if (test1[di1]!=decomp1[di1]) { dec_okű0 }
  di1űdi1+1
  if (di1>200) { break }
}
if (dec_ok=1) {
  Ő \"lzw: [PASS] decompress matches original\"
} else {
  Ő \"lzw: [FAIL] decompress does not match original\"
}

ă --- Test 3: Verify dictionary grows beyond 256 ---
lzw_init_dict{}
if (dict_size=256) {
  Ő \"lzw: [PASS] dictionary initialized with 256 entries\"
} else {
  Ő \"lzw: [FAIL] dictionary init wrong size\"
}
ă After compression, dict should have grown
ă Re-compress to get final dict state
tmp_c2űlzw_compress{test1}
if (dict_size > 256) {
  Ő \"lzw: [PASS] dictionary grew beyond 256 entries\"
} else {
  Ő \"lzw: [FAIL] dictionary did not grow\"
}
  Ő \"lzw: final dictionary size:\"
  Ő dict_size

ă --- Test 4: Round-trip all 256 byte values ---
test4ű256Î0
i4aű0
while (i4a<256) {
  test4[i4a]űi4a
  i4aűi4a+1
}
comp4űlzw_compress{test4}
decomp4űlzw_decompress{comp4}
