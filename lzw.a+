i4bű0
while ((i4b<256) & rt4_ok) {
  if (decomp4[i4b]!=test4[i4b]) { rt4_okű0 }
  i4bűi4b+1
}
if (rt4_ok=1) {
  Ő \"lzw: [PASS] round-trip all 256 byte values\"
} else {
  Ő \"lzw: [FAIL] round-trip failed for all 256 bytes\"
}

ă --- Test 5: Repeated characters compress well ---
ă 50 A's (ASCII 65)
test5ű50Î65
comp5űlzw_compress{test5}
code_count5ű0
ci5ű0
while (comp5[ci5]>=0) {
