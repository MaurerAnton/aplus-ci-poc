while (d5_idx<d5_ns) {
  seedŻd5_seeds[d5_idx]
  soilŻd5_lookup{seed;d5_s2s}
  fertŻd5_lookup{soil;d5_s2f}
  waterŻd5_lookup{fert;d5_f2w}
  lightŻd5_lookup{water;d5_w2l}
  tempŻd5_lookup{light;d5_l2t}
  humŻd5_lookup{temp;d5_t2h}
  locŻd5_lookup{hum;d5_h2l}
  if (loc<d5_minloc) { d5_minlocŻloc }
