d7_b5Ż483

„ Rank hands by pairwise comparison (bubble sort)
d7_handsŻd7_h1 d7_h2 d7_h3 d7_h4 d7_h5
d7_bidsŻd7_b1 d7_b2 d7_b3 d7_b4 d7_b5
d7_nŻ5

„ Compute rank for each hand: rank[i] = number of hands weaker than it + 1
d7_totalŻ0
d7_iŻ0
while (d7_i<d7_n) {
  d7_rankŻ1
  d7_jŻ0
  while (d7_j<d7_n) {
    if (d7_i!=d7_j) {
      if (d7_weaker{d7_hands[d7_j];d7_hands[d7_i]}=1) { d7_rankŻd7_rank+1 }
    }
    d7_jŻd7_j+1
  }
  d7_totalŻd7_total+d7_rankŖd7_bids[d7_i]
  d7_iŻd7_i+1
}

