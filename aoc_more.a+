„ ===================================
„ Day 10: Pipe Maze
„ Find farthest point in loop from start S.
„ Example grid (5x5):
„   .....
„   .S-7.
„   .|.|.
„   .L-J.
„   .....
„ S is at (1,1). Loop: S-(2,1)--(3,1)-7, down to (3,2)|, down to (3,3)J,
„ left to (2,3)-, left to (1,3)L, up to (1,2)|, back to S.
„ Loop length = 8, farthest = 4.
„ Expected: 4
„ ===================================

„ Grid as flat string (5x5=25 chars)
d10_gridŻ"....." ".S-7." ".|.|." ".L-J." "....."
d10_rowsŻ5
d10_colsŻ5
d10_flatŻ0ő25
d10_iŻ0
while (d10_i<5) {
  d10_rowŻd10_grid[d10_i]
  d10_jŻ0
  while (d10_j<5) {
    d10_flat[d10_iŖ5+d10_j]Żd10_row[d10_j]
    d10_jŻd10_j+1
  }
  d10_iŻd10_i+1
}

„ Find S
d10_srŻ0-1
d10_scŻ0-1
d10_rŻ0
while (d10_r<d10_rows) {
  d10_cŻ0
  while (d10_c<d10_cols) {
    if (d10_flat[d10_rŖ5+d10_c]=83) {
      d10_srŻd10_r
      d10_scŻd10_c
    }
    d10_cŻd10_c+1
  }
  d10_rŻd10_r+1
}

„ Distance array
d10_distŻ25ő0-1

„ BFS from S
d10_queue_rŻ100ő0
d10_queue_cŻ100ő0
d10_qhŻ0
d10_qtŻ0
d10_queue_r[0]Żd10_sr
d10_queue_c[0]Żd10_sc
d10_qtŻ1
d10_dist[d10_srŖ5+d10_sc]Ż0

„ Pipe connections: for each pipe char, which directions it connects
„ Directions: 0=up, 1=right, 2=down, 3=left
„ | = up+down (0,2); - = left+right (1,3); L = up+right (0,1)
„ J = up+left (0,3); 7 = down+left (2,3); F = down+right (1,2)
„ For S, connect to all adjacent pipes

„ Check if two pipes connect
d10_conn{ch;dir}:
{
  rŻ0
  if (ch=124) { if ((dir=0)|(dir=2)) { rŻ1 } }     „ | = 124: up, down
  if (ch=45)  { if ((dir=1)|(dir=3)) { rŻ1 } }     „ - = 45: left, right
  if (ch=76)  { if ((dir=0)|(dir=1)) { rŻ1 } }     „ L = 76: up, right
  if (ch=74)  { if ((dir=0)|(dir=3)) { rŻ1 } }     „ J = 74: up, left
  if (ch=55)  { if ((dir=2)|(dir=3)) { rŻ1 } }     „ 7 = 55: down, left
  if (ch=70)  { if ((dir=1)|(dir=2)) { rŻ1 } }     „ F = 70: down, right
  if (ch=83)  { rŻ1 }                               „ S = 83: all directions
  r
}

„ Opposite direction: 0<->2, 1<->3
d10_opp{d}:
{
  oŻd
  if (d=0) { oŻ2 }
  if (d=1) { oŻ3 }
  if (d=2) { oŻ0 }
  if (d=3) { oŻ1 }
  o
}

„ Direction offsets: dr[0]=-1, dc[0]=0; dr[1]=0, dc[1]=1; dr[2]=1, dc[2]=0; dr[3]=0, dc[3]=-1
d10_drŻ0-1 0 1 0
d10_dcŻ0 1 0 0-1

while (d10_qh<d10_qt) {
  crŻd10_queue_r[d10_qh]
  ccŻd10_queue_c[d10_qh]
  cdŻd10_dist[crŖ5+cc]
  d10_qhŻd10_qh+1
  d10_dirŻ0
  while (d10_dir<4) {
    nrŻcr+d10_dr[d10_dir]
    ncŻcc+d10_dc[d10_dir]
    if ((nr>=0) & (nr<d10_rows) & (nc>=0) & (nc<d10_cols)) {
      nchŻd10_flat[nrŖ5+nc]
      „ Check if current pipe allows this direction
      cchŻd10_flat[crŖ5+cc]
      if (d10_conn{cch;d10_dir}=1) {
        „ Check if neighbor allows the opposite direction
        odirŻd10_opp{d10_dir}
        if (d10_conn{nch;odir}=1) {
          if (d10_dist[nrŖ5+nc]<0) {
            d10_dist[nrŖ5+nc]Żcd+1
            d10_queue_r[d10_qt]Żnr
            d10_queue_c[d10_qt]Żnc
            d10_qtŻd10_qt+1
          }
        }
      }
    }
    d10_dirŻd10_dir+1
  }
}

„ Find max distance
d10_maxŻ0
d10_iŻ0
while (d10_i<25) {
  if (d10_dist[d10_i]>d10_max) { d10_maxŻd10_dist[d10_i] }
  d10_iŻd10_i+1
}

if (d10_max=4) { ’"AoC D10: [PASS] farthest=4" } else { ’"AoC D10: [FAIL] farthest" }

