„ ===================================
„ Day 6: Wait For It
„ Boat race: distance = (time-hold)*hold
„ Count ways to beat record for each race, multiply results
„ Races: time=7 dist=9; time=15 dist=40; time=30 dist=200
„ Expected product: 4*8*9 = 288
„ ===================================

d6_w1Ż0
d6_holdŻ1
while (d6_hold<7) {
  d6_distŻ(7-d6_hold)Ŗd6_hold
  if (d6_dist>9) { d6_w1Żd6_w1+1 }
  d6_holdŻd6_hold+1
}

d6_w2Ż0
d6_holdŻ1
while (d6_hold<15) {
  d6_distŻ(15-d6_hold)Ŗd6_hold
  if (d6_dist>40) { d6_w2Żd6_w2+1 }
  d6_holdŻd6_hold+1
}

d6_w3Ż0
d6_holdŻ1
while (d6_hold<30) {
  d6_distŻ(30-d6_hold)Ŗd6_hold
  if (d6_dist>200) { d6_w3Żd6_w3+1 }
  d6_holdŻd6_hold+1
}

d6_resultŻd6_w1Ŗd6_w2Ŗd6_w3

if (d6_w1=4) { ’"AoC D6: [PASS] race1=4" } else { ’"AoC D6: [FAIL] race1" }
if (d6_w2=8) { ’"AoC D6: [PASS] race2=8" } else { ’"AoC D6: [FAIL] race2" }
if (d6_w3=9) { ’"AoC D6: [PASS] race3=9" } else { ’"AoC D6: [FAIL] race3" }
if (d6_result=288) { ’"AoC D6: [PASS] product=288" } else { ’"AoC D6: [FAIL] product" }

„ ===================================
„ Day 7: Camel Cards
„ Rank poker hands. With J-as-joker variant, J is weakest card
„ but acts as wildcard for hand type determination.
„ Hands: 32T3K 765, T55J5 684, KK677 28, KTJJT 220, QQQJA 483
„ Expected total winnings: 5905
„ ===================================

„ Card values: J=0, 2=1, 3=2, 4=3, 5=4, 6=5, 7=6, 8=7, 9=8, T=9, Q=10, K=11, A=12
„ Hand type values: high-card=0, one-pair=1, two-pair=2, three-kind=3,
„   full-house=4, four-kind=5, five-kind=6

„ Function: get card value from character code
d7_cardval{ch}:
{
  valŻ0
  if (ch=74) { valŻ0 }        „ J=74
  if (ch=50) { valŻ1 }        „ 2=50
  if (ch=51) { valŻ2 }        „ 3=51
  if (ch=52) { valŻ3 }        „ 4=52
  if (ch=53) { valŻ4 }        „ 5=53
  if (ch=54) { valŻ5 }        „ 6=54
  if (ch=55) { valŻ6 }        „ 7=55
  if (ch=56) { valŻ7 }        „ 8=56
  if (ch=57) { valŻ8 }        „ 9=57
  if (ch=84) { valŻ9 }        „ T=84
  if (ch=81) { valŻ10 }       „ Q=81
  if (ch=75) { valŻ11 }       „ K=75
  if (ch=65) { valŻ12 }       „ A=65
  val
}

„ Function: determine hand type with J as joker
„ counts[0..12] for cards J..A, jokers=counts[0]
d7_handtype{hand}:
{
  „ Count cards
  countsŻ13ő0
  num_jŻ0
  iŻ0
  while (i<5) {
    chŻhand[i]
    cvŻd7_cardval{ch}
    counts[cv]Żcounts[cv]+1
    iŻi+1
  }
  jokersŻcounts[0]
  „ Find max non-joker count
  maxcŻ0
  iŻ1
  while (i<13) {
    if (counts[i]>maxc) { maxcŻcounts[i] }
    iŻi+1
  }
  „ Best hand type with jokers
  bestŻmaxc+jokers
  „ Check for two-pair: need two distinct pairs
  pairsŻ0
  iŻ1
  while (i<13) {
    if (counts[i]=2) { pairsŻpairs+1 }
    iŻi+1
  }
  htypeŻ0
  if (best=5) { htypeŻ6 }              „ five of a kind
  if (best=4) { htypeŻ5 }              „ four of a kind
  if (best=3) {
    „ Could be full house or three of a kind
    if (pairs=2) { htypeŻ4 }           „ full house
    else {
      if (jokers=0) {
        if (pairs=1) { htypeŻ4 }       „ full house (3+2)
        if (pairs=0) { htypeŻ3 }       „ three of a kind
      }
      if (jokers>0) { htypeŻ3 }        „ can't be full house with joker making 3
    }
  }
  if (best=2) {
    if (pairs=2) { htypeŻ2 }           „ two pair
    if (pairs=1) { htypeŻ1 }           „ one pair
    if (pairs=0) { htypeŻ1 }           „ one pair from joker+1
  }
  if (best=1) { htypeŻ0 }              „ high card
  htype
}

„ Function: compare two hands, return 1 if hand1 < hand2 (weaker), 0 otherwise
d7_weaker{h1;h2}:
{
  t1Żd7_handtype{h1}
  t2Żd7_handtype{h2}
  resultŻ0
  if (t1<t2) { resultŻ1 }
  if (t1=t2) {
    iŻ0
    while ((i<5) & (result=0)) {
      cv1Żd7_cardval{h1[i]}
      cv2Żd7_cardval{h2[i]}
      if (cv1<cv2) { resultŻ1 }
      if (cv1>cv2) { resultŻ0; iŻ5 }
      iŻi+1
    }
  }
  result
}

