„ ===================================
„ Day 9: Mirage Maintenance
„ Extrapolate next value in sequences by computing successive differences
„ until all zeros, then sum the last values.
„ Example: [0 3 6 9 12 15]->18, [1 3 6 10 15 21]->28, [10 13 16 21 30 45]->68
„ Expected sum: 114
„ ===================================

„ Function: extrapolate next value for a sequence
d9_extrap{seq}:
{
  nŻő seq
  „ Store the last value of each difference level
  lastsŻseq[n-1]
  „ Work array - copy of seq
  workŻnő0
  iŻ0
  while (i<n) {
    work[i]Żseq[i]
    iŻi+1
  }
  cur_nŻn
  doneŻ0
  while (done=0) {
    „ Compute differences
    new_nŻcur_n-1
    diffŻnew_nő0
    allzeroŻ1
    iŻ0
    while (i<new_n) {
      diff[i]Żwork[i+1]-work[i]
      if (diff[i]!=0) { allzeroŻ0 }
      iŻi+1
    }
    lastsŻlasts,diff[new_n-1]
    if (allzero=1) { doneŻ1 }
    „ Copy diff to work
    workŻnew_nő0
    iŻ0
    while (i<new_n) {
      work[i]Żdiff[i]
      iŻi+1
    }
    cur_nŻnew_n
  }
  „ Sum the last values
  resultŻ0
  nlŻő lasts
  iŻ0
  while (i<nl) {
    resultŻresult+lasts[i]
    iŻi+1
  }
  result
}

d9_s1Ż0 3 6 9 12 15
d9_s2Ż1 3 6 10 15 21
d9_s3Ż10 13 16 21 30 45

d9_e1Żd9_extrap{d9_s1}
d9_e2Żd9_extrap{d9_s2}
d9_e3Żd9_extrap{d9_s3}
d9_sumŻd9_e1+d9_e2+d9_e3

if (d9_e1=18) { ’"AoC D9: [PASS] seq1=18" } else { ’"AoC D9: [FAIL] seq1" }
if (d9_e2=28) { ’"AoC D9: [PASS] seq2=28" } else { ’"AoC D9: [FAIL] seq2" }
if (d9_e3=68) { ’"AoC D9: [PASS] seq3=68" } else { ’"AoC D9: [FAIL] seq3" }
