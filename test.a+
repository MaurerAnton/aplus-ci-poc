„ test.a+ - unit testing framework for A+
„ Usage: $load test   then: test.ok{} test.fail{} test.summary{}

passesŻ0
failsŻ0

„ Assert: mark a test as passed
ok{}: {
  passesŻpasses+1
  ’"  [PASS]"
}

„ Assert: mark a test as failed
fail{}: {
  failsŻfails+1
  ’"  [FAIL]"
}

„ Run an assertion (1 = pass, 0 = fail)
check{cond}: {
  if (cond) { ok{} } else { fail{} }
}

„ Print test summary
summary{}: {
  ’"===== Test Summary ====="
  ’"Passes:"
  passes
  ’"Fails:"
  fails
  ’"========================"
}
