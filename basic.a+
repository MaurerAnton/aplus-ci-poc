ă ====== Program Storage ======
progű1000Î0
prog_ptrű0
program_loadedű0

ă Load a program from char-code array (the source text)
ă Format: each line is 'line_number statement...'
basic_load{src}: {
  nűÎ src
  prog_ptrű0
  posű0
  while (pos < n) {
    ă Skip whitespace before line number
    while ((pos<n) & ((src[pos]=32) | (src[pos]=9) | (src[pos]=10) | (src[pos]=13))) {
      posűpos+1
    }
    if (pos>=n) { break }
    ă Parse line number
    lnű0
    while ((pos<n) & (src[pos]>=48) & (src[pos]<=57)) {
      lnűlnÁ10 + (src[pos]-48)
      posűpos+1
    }
    ă Skip whitespace after line number
    while ((pos<n) & ((src[pos]=32) | (src[pos]=9))) {
      posűpos+1
    }
    ă Store line number
    prog[prog_ptr]űln
    prog_ptrűprog_ptr+1
    ă Store line length placeholder
    len_posűprog_ptr
    prog[prog_ptr]ű0
    prog_ptrűprog_ptr+1
    ă Store line content until newline or end
    line_lenű0
    while ((pos<n) & (src[pos]!=10) & (src[pos]!=13)) {
      prog[prog_ptr]űsrc[pos]
      prog_ptrűprog_ptr+1
      line_lenűline_len+1
      posűpos+1
    }
    ă Backfill line length
    prog[len_pos]űline_len
    ă Skip newlines
    while ((pos<n) & ((src[pos]=10) | (src[pos]=13))) {
      posűpos+1
    }
  }
  program_loadedű1
  prog_ptr
}

ă ====== Expression Evaluator (recursive descent) ======
ă Evaluate a complete expression, returning [value, new_pos]
basic_expr{src;pos;len}: {
  ă Step 1: evaluate term (+ and -)
  result_posűbasic_term{src;pos;len}
  resultűresult_pos[0]
  posűresult_pos[1]
  while (pos < len) {
    ă Skip whitespace
    while ((pos<len) & ((src[pos]=32) | (src[pos]=9))) { posűpos+1 }
    chűsrc[pos]
    if (ch=43) {
      posűpos+1
      tpűbasic_term{src;pos;len}
      resultűresult + tp[0]
      posűtp[1]
    }
    if (ch=45) {
      posűpos+1
      tpűbasic_term{src;pos;len}
      resultűresult - tp[0]
      posűtp[1]
    }
    if ((ch!=43) & (ch!=45)) { break }
  }
  result,pos
}

ă Evaluate a term (* and /)
basic_term{src;pos;len}: {
  result_posűbasic_factor{src;pos;len}
  resultűresult_pos[0]
  posűresult_pos[1]
  while (pos < len) {
    while ((pos<len) & ((src[pos]=32) | (src[pos]=9))) { posűpos+1 }
    chűsrc[pos]
    if (ch=42) {
      posűpos+1
      fpűbasic_factor{src;pos;len}
      resultűresult Á fp[0]
      posűfp[1]
    }
    if (ch=47) {
      posűpos+1
      fpűbasic_factor{src;pos;len}
      if (fp[0]!=0) { resultűresult ß fp[0] }
      posűfp[1]
    }
    if ((ch!=42) & (ch!=47)) { break }
  }
  result,pos
}

ă Evaluate a factor (number, variable, or parenthesized expression)
basic_factor{src;pos;len}: {
  while ((pos<len) & ((src[pos]=32) | (src[pos]=9))) { posűpos+1 }
  chűsrc[pos]
  ă Parenthesized expression
  if (ch=40) {
    posűpos+1
    rpűbasic_expr{src;pos;len}
    valűrp[0]
    posűrp[1]
    while ((pos<len) & ((src[pos]=32) | (src[pos]=9))) { posűpos+1 }
    if ((pos<len) & (src[pos]=41)) { posűpos+1 }
    val,pos
  }
  ă Number
  if ((ch>=48) & (ch<=57)) {
    valű0
    while ((pos<len) & (src[pos]>=48) & (src[pos]<=57)) {
      valűvalÁ10 + (src[pos]-48)
      posűpos+1
    }
    val,pos
  }
  ă Variable (A-Z)
  if ((ch>=65) & (ch<=90)) {
    valűvar_get{ch}
    posűpos+1
    val,pos
  }
  ă Negative number or unary minus
  if (ch=45) {
    posűpos+1
    fpűbasic_factor{src;pos;len}
    -fp[0],fp[1]
  }
  0,pos
}

ă ====== Condition Evaluator ======
ă Returns 1 if condition is true, 0 if false
basic_cond{src;pos;len}: {
  ă Evaluate left side
  lpűbasic_expr{src;pos;len}
  leftűlp[0]
  posűlp[1]
  ă Skip whitespace
  while ((pos<len) & ((src[pos]=32) | (src[pos]=9))) { posűpos+1 }
  ă Detect operator
  opűsrc[pos]
  ă Check for two-char operators: <=, >=, <>
  op2ű0
  if (pos+1<len) { op2űsrc[pos+1] }
  ă Handle combined operators
  resultű0
  if ((op=60) & (op2=62)) {
    posűpos+2
    rpűbasic_expr{src;pos;len}
    rightűrp[0]
    posűrp[1]
    if (left!=right) { resultű1 }
  }
  if ((op=60) & (op2=61)) {
    posűpos+2
    rpűbasic_expr{src;pos;len}
    rightűrp[0]
    posűrp[1]
    if ((left<right) | (left=right)) { resultű1 }
  }
  if ((op=62) & (op2=61)) {
    posűpos+2
    rpűbasic_expr{src;pos;len}
    rightűrp[0]
    posűrp[1]
    if ((left>right) | (left=right)) { resultű1 }
  }
  ă Single-char operators: = < >
  if ((op=61) & (op2!=60) & (op2!=62)) {
    posűpos+1
    rpűbasic_expr{src;pos;len}
    rightűrp[0]
    posűrp[1]
    if (left=right) { resultű1 }
  }
  if ((op=60) & (op2!=62) & (op2!=61)) {
    posűpos+1
    rpűbasic_expr{src;pos;len}
    rightűrp[0]
    posűrp[1]
    if (left<right) { resultű1 }
  }
  if ((op=62) & (op2!=61)) {
    posűpos+1
    rpűbasic_expr{src;pos;len}
    rightűrp[0]
    posűrp[1]
    if (left>right) { resultű1 }
  }
  result,pos
}

ă ====== String Matching (keyword detection) ======
basic_starts_with{src;pos;len;kw}: {
  kwlenűÎ kw
  if (pos+kwlen > len) { 0 }
  matchű1
  iű0
  while (i<kwlen) {
    if (src[pos+i]=kw[i]) { } else { matchű0 }
    iűi+1
  }
  match
}

ă Skip whitespace and return new pos
basic_skip_ws{src;pos;len}: {
  while ((pos<len) & ((src[pos]=32) | (src[pos]=9))) { posűpos+1 }
  pos
}

ă ====== Find line index in program by line number ======
ă Returns line index (0-based, into prog array) or -1
basic_find_line{ln}: {
  idxű0
  while (idx < prog_ptr) {
    if (prog[idx]=ln) { idx }
    line_lenűprog[idx+1]
    idxűidx + 2 + line_len
  }
  -1
}

ă ====== Execute One Line ======
ă Given index into prog, execute that line. Returns next line index or -1 for END.
basic_exec_line{line_idx}: {
  ă Extract line data
  lnűprog[line_idx]
  line_lenűprog[line_idx+1]
  ă Copy line content to local array for parsing
  line_srcűline_lenÎ0
  kű0
  while (k<line_len) {
    line_src[k]űprog[line_idx+2+k]
    kűk+1
  }
  posű0
  posűbasic_skip_ws{line_src;pos;line_len}
  ă --- LET ---
  if (basic_starts_with{line_src;pos;line_len;76,69,84}) {
    posűpos+3
    posűbasic_skip_ws{line_src;pos;line_len}
    var_chűline_src[pos]
    posűpos+1
    posűbasic_skip_ws{line_src;pos;line_len}
    ă Expect '='
    if ((pos<line_len) & (line_src[pos]=61)) {
      posűpos+1
      epűbasic_expr{line_src;pos;line_len}
      var_set{var_ch;ep[0]}
    }
    ă Advance to next line in program
    line_idx + 2 + line_len
  }
  ă --- PRINT ---
  if (basic_starts_with{line_src;pos;line_len;80,82,73,78,84}) {
    posűpos+5
    posűbasic_skip_ws{line_src;pos;line_len}
    epűbasic_expr{line_src;pos;line_len}
    Ő ep[0]
    line_idx + 2 + line_len
  }
  ă --- IF cond THEN line# ---
  if (basic_starts_with{line_src;pos;line_len;73,70}) {
    posűpos+2
    posűbasic_skip_ws{line_src;pos;line_len}
    cpűbasic_cond{line_src;pos;line_len}
    cond_valűcp[0]
    posűcp[1]
    posűbasic_skip_ws{line_src;pos;line_len}
    ă Expect THEN
    if (basic_starts_with{line_src;pos;line_len;84,72,69,78}) {
      posűpos+4
      posűbasic_skip_ws{line_src;pos;line_len}
      ă Parse target line number
      targetű0
      while ((pos<line_len) & (line_src[pos]>=48) & (line_src[pos]<=57)) {
        targetűtargetÁ10 + (line_src[pos]-48)
        posűpos+1
      }
      if (cond_val) {
        ă Jump to target line
        tgt_idxűbasic_find_line{target}
        if (tgt_idx >= 0) { tgt_idx }
        if (tgt_idx < 0) { line_idx + 2 + line_len }
      }
      if (cond_val=0) { line_idx + 2 + line_len }
    }
    if (basic_starts_with{line_src;pos;line_len;84,72,69,78}=0) {
      line_idx + 2 + line_len
    }
  }
  ă --- GOTO line# ---
  if (basic_starts_with{line_src;pos;line_len;71,79,84,79}) {
    posűpos+4
    posűbasic_skip_ws{line_src;pos;line_len}
    targetű0
    while ((pos<line_len) & (line_src[pos]>=48) & (line_src[pos]<=57)) {
      targetűtargetÁ10 + (line_src[pos]-48)
      posűpos+1
    }
    tgt_idxűbasic_find_line{target}
    if (tgt_idx >= 0) { tgt_idx }
    if (tgt_idx < 0) { -1 }
  }
  ă --- INPUT X (read from user - we just set to 0 for testing) ---
  if (basic_starts_with{line_src;pos;line_len;73,78,80,85,84}) {
    posűpos+5
    posűbasic_skip_ws{line_src;pos;line_len}
    ă Get variable name
    var_chűline_src[pos]
    posűpos+1
    ă In this interpreter, INPUT defaults to 0 for testing
    var_set{var_ch;0}
    line_idx + 2 + line_len
  }
  ă --- END ---
  if (basic_starts_with{line_src;pos;line_len;69,78,68}) {
    -1
  }
  ă Default: advance to next line
  line_idx + 2 + line_len
}

ă ====== Main Execution Loop ======
basic_run{}: {
  if (program_loaded=0) {
    Ő "BASIC: No program loaded"
    0
  }
  ă Find first line (lowest line number)
  line_idxű0
  min_lnű99999
  first_idxű0
  ă Scan to find first line
  iű0
  while (i < prog_ptr) {
    this_lnűprog[i]
    if (this_ln < min_ln) {
      min_lnűthis_ln
      first_idxűi
    }
    iűi + 2 + prog[i+1]
  }
  line_idxűfirst_idx
  ă Execute lines until END or out of bounds
  while ((line_idx >= 0) & (line_idx < prog_ptr)) {
    line_idxűbasic_exec_line{line_idx}
  }
  1
}

