‚çù =====================================================================
‚çù Day 3: Gear Ratios
‚çù Find numbers adjacent to symbols in engine schematic
‚çù =====================================================================

‚çù Sample schematic (10x10 grid, flat string, no newlines)
‚çù 467..114..
‚çù ...*......
‚çù ..35..633.
‚çù ......#...
‚çù 617*......
‚çù .....+.58.
‚çù ..592.....
‚çù ......755.
‚çù ...$.*....
‚çù .664.598..
‚çù Part numbers adjacent to symbols: 467(*), 35(*), 633(#), 617(*), 592(+), 755(*), 664($), 598(*)
‚çù Sum = 467+35+633+617+592+755+664+598 = 4361

d3_schematic‚Üê"467..114.....*........35..633........#...617*...........+.58...592...........755....$.*.......664.598.."
d3_rows‚Üê10
d3_cols‚Üê10
d3_total‚Üê0
d3_r‚Üê0
‚çù For each position, check if a number starts there and is adjacent to a symbol
while (d3_r<d3_rows) {
  d3_c‚Üê0
  while (d3_c<d3_cols) {
    ch‚Üêd3_schematic[d3_r√ód3_cols+d3_c]
    if ((ch>="0") & (ch<="9")) {
      ‚çù Start of a number ‚Äî extract it
      d‚Üê0
      if (ch="0") { d‚Üê0 }
      if (ch="1") { d‚Üê1 }
      if (ch="2") { d‚Üê2 }
      if (ch="3") { d‚Üê3 }
      if (ch="4") { d‚Üê4 }
      if (ch="5") { d‚Üê5 }
      if (ch="6") { d‚Üê6 }
      if (ch="7") { d‚Üê7 }
      if (ch="8") { d‚Üê8 }
      if (ch="9") { d‚Üê9 }
      d3_num‚Üêd
      d3_startc‚Üêd3_c
      ‚çù Check for adjacent symbol around (r, c)
      d3_adjacent‚Üê0
      d3_dr‚Üê0-1
      while ((d3_dr<=1) & (d3_adjacent=0)) {
        d3_dc‚Üê0-1
        while ((d3_dc<=1) & (d3_adjacent=0)) {
          d3_nr‚Üêd3_r+d3_dr
          d3_nc‚Üêd3_c+d3_dc
          if ((d3_nr>=0) & (d3_nr<d3_rows) & (d3_nc>=0) & (d3_nc<d3_cols)) {
            chk‚Üêd3_schematic[d3_nr√ód3_cols+d3_nc]
            if (chk="*") { d3_adjacent‚Üê1 }
            if (chk="#") { d3_adjacent‚Üê1 }
            if (chk="+") { d3_adjacent‚Üê1 }
            if (chk="$") { d3_adjacent‚Üê1 }
            if (chk="@") { d3_adjacent‚Üê1 }
            if (chk="%") { d3_adjacent‚Üê1 }
            if (chk="&") { d3_adjacent‚Üê1 }
            if (chk="/") { d3_adjacent‚Üê1 }
            if (chk="=") { d3_adjacent‚Üê1 }
            if (chk="-") { d3_adjacent‚Üê1 }
          }
          d3_dc‚Üêd3_dc+1
        }
        d3_dr‚Üêd3_dr+1
      }
      ‚çù Consume remaining digits of the number
      d3_c‚Üêd3_c+1
      d3_inner‚Üê1
      while ((d3_c<d3_cols) & (d3_inner=1)) {
        ch2‚Üêd3_schematic[d3_r√ód3_cols+d3_c]
        if ((ch2>="0") & (ch2<="9")) {
          d2‚Üê0
          if (ch2="0") { d2‚Üê0 }
          if (ch2="1") { d2‚Üê1 }
          if (ch2="2") { d2‚Üê2 }
          if (ch2="3") { d2‚Üê3 }
          if (ch2="4") { d2‚Üê4 }
          if (ch2="5") { d2‚Üê5 }
          if (ch2="6") { d2‚Üê6 }
          if (ch2="7") { d2‚Üê7 }
          if (ch2="8") { d2‚Üê8 }
          if (ch2="9") { d2‚Üê9 }
          d3_num‚Üêd3_num√ó10+d2
          ‚çù Also check adjacency for this digit if not already adjacent
          if (d3_adjacent=0) {
            d3_dr2‚Üê0-1
            while ((d3_dr2<=1) & (d3_adjacent=0)) {
              d3_dc2‚Üê0-1
              while ((d3_dc2<=1) & (d3_adjacent=0)) {
                d3_nr2‚Üêd3_r+d3_dr2
                d3_nc2‚Üêd3_c+d3_dc2
                if ((d3_nr2>=0) & (d3_nr2<d3_rows) & (d3_nc2>=0) & (d3_nc2<d3_cols)) {
                  chk2‚Üêd3_schematic[d3_nr2√ód3_cols+d3_nc2]
                  if (chk2="*") { d3_adjacent‚Üê1 }
                  if (chk2="#") { d3_adjacent‚Üê1 }
                  if (chk2="+") { d3_adjacent‚Üê1 }
                  if (chk2="$") { d3_adjacent‚Üê1 }
                  if (chk2="@") { d3_adjacent‚Üê1 }
                  if (chk2="%") { d3_adjacent‚Üê1 }
                  if (chk2="&") { d3_adjacent‚Üê1 }
                  if (chk2="/") { d3_adjacent‚Üê1 }
                  if (chk2="=") { d3_adjacent‚Üê1 }
                  if (chk2="-") { d3_adjacent‚Üê1 }
                }
                d3_dc2‚Üêd3_dc2+1
              }
              d3_dr2‚Üêd3_dr2+1
            }
          }
          d3_c‚Üêd3_c+1
        } else { d3_inner‚Üê0 }
      }
      if (d3_adjacent=1) { d3_total‚Üêd3_total+d3_num }
    }
    d3_c‚Üêd3_c+1
  }
  d3_r‚Üêd3_r+1
}
if (d3_total=4361) { ‚éï"AoC D3: [PASS] gear ratio sum = 4361" } else { ‚éï"AoC D3: [FAIL]" }


‚éï"advent_of_code: all 3 days done"
