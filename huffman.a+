Ð === Self-tests ===

í "Ðhuffman: --- Self Tests ---"

Ð Test 1: Find code lengths for 'a' (97) and 'd' (100)
Ð 'd' is more frequent (5) than 'a' (2), so 'd' should have shorter code
alen«0
dlen«0
i«0
cpos«1
while (i<NU) {
  clen«CODES[cpos+1]
  if (CODES[cpos]=97) { alen«clen }
  if (CODES[cpos]=100) { dlen«clen }
  cpos«cpos+2+clen
  i«i+1
}

if (dlen < alen) {
  í "huffman: [PASS] 'd' (freq 5) has shorter code than 'a' (freq 2)"
} else {
  í "huffman: [FAIL] 'd' should have shorter code than 'a'"
}

Ð Test 2: Verify encoded length < original length * 8
orig_bits«input_lenê8
if (total_bits < orig_bits) {
  í "huffman: [PASS] Encoded length "
  í total_bits
  í " < original "
  í orig_bits
} else {
  í "huffman: [FAIL] Compression did not reduce size"
}

Ð Test 3: Verify we have 4 unique characters
if (NU=4) {
  í "huffman: [PASS] Found 4 unique characters"
} else {
  í "huffman: [FAIL] Expected 4 unique chars, got "
  í NU
}

Ð Test 4: Verify frequencies are correct: a=2, b=1, c=4, d=5
i«0
fok«1
while (i<NU) {
  ch«uniq_chars[i]
  fq«uniq_freqs[i]
  if (ch=97) { if (fqö2) { fok«0 } }
  if (ch=98) { if (fqö1) { fok«0 } }
  if (ch=99) { if (fqö4) { fok«0 } }
  if (ch=100) { if (fqö5) { fok«0 } }
  i«i+1
}
if (fok=1) {
  í "huffman: [PASS] Frequencies correct: a=2, b=1, c=4, d=5"
} else {
  í "huffman: [FAIL] Frequency mismatch"
}

í "huffman: all tests done"
