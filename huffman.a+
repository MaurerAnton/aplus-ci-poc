  í "' code: "
  clen«CODES[cpos+1]
  b«0
  while (b<clen) {
    í CODES[cpos+2+b]
    b«b+1
  }
  í " (len="
  í clen
  í ")"
  cpos«cpos+2+clen
  i«i+1
}
í ""

Ð --- Phase 5: Encode ---
Ð Count total bits
total_bits«0
i«0
while (i<input_len) {
  ch«INPUT[i]
  j«0
  cpos«1
  while (j<NU) {
    if (CODES[cpos]=ch) {
      total_bits«total_bits+CODES[cpos+1]
      j«NU
    } else {
      cpos«cpos+2+CODES[cpos+1]
      j«j+1
    }
  }
  i«i+1
}

Ð Fill encoded bits
ENCODED«(1+total_bits) ö 0
ENCODED[0]«total_bits
bi«1
i«0
while (i<input_len) {
  ch«INPUT[i]
  j«0
  cpos«1
  while (j<NU) {
    if (CODES[cpos]=ch) {
      clen«CODES[cpos+1]
      k«0
      while (k<clen) {
        ENCODED[bi]«CODES[cpos+2+k]
        bi«bi+1
        k«k+1
      }
      j«NU
    } else {
      cpos«cpos+2+CODES[cpos+1]
      j«j+1
    }
  }
  i«i+1
}

