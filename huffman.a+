Ð But build_tree uses local arrays; we need them globally.
Ð Rebuild with global arrays and return root index.
Ð Actually, let me restructure: have build_tree return everything needed.

Ð Let me redo this more carefully. build_tree sets up the arrays
Ð and assign_codes uses them. I'll make the arrays accessible.
Ð 
Ð Simplification: do everything in one linear flow.

Ð --- Phase 1: Frequency counting ---
input_len«ö INPUT
uniq_chars«0 ö 0
uniq_freqs«0 ö 0
i«0
while (i<input_len) {
  ch«INPUT[i]
  found«0
  j«0
  ncu«ö uniq_chars
  while (j<ncu) {
    if (uniq_chars[j]=ch) {
      uniq_freqs[j]«uniq_freqs[j]+1
      found«1
      j«ncu
    }
    j«j+1
  }
  if (found=0) {
    uniq_chars«uniq_chars,ch
    uniq_freqs«uniq_freqs,1
  }
  i«i+1
}

NU«ö uniq_chars
NN«NU+NU-1

Ð --- Phase 2: Build tree ---
HL«NN ö 0
HC«NN ö 0
HF«NN ö 0
HLEFT«NN ö 0
HRIGHT«NN ö 0
HACT«NN ö 1

i«0
while (i<NU) {
  HL[i]«1
  HC[i]«uniq_chars[i]
  HF[i]«uniq_freqs[i]
  HLEFT[i]«-1
  HRIGHT[i]«-1
  i«i+1
}

next_idx«NU
round«0
while (round < NU-1) {
  min1«-1
  min2«-1
  fmin1«999999
  fmin2«999999
  i«0
  while (i<next_idx) {
    if (HACT[i]=1) {
      f«HF[i]
      if (f < fmin1) {
        min2«min1
        fmin2«fmin1
        min1«i
        fmin1«f
      } else {
        if (f < fmin2) {
          min2«i
          fmin2«f
        }
      }
    }
    i«i+1
  }
  HACT[min1]«0
  HACT[min2]«0
  HL[next_idx]«0
  HC[next_idx]«-1
  HF[next_idx]«fmin1+fmin2
  HLEFT[next_idx]«min1
  HRIGHT[next_idx]«min2
  HACT[next_idx]«1
  next_idx«next_idx+1
  round«round+1
}

ROOT«next_idx-1

Ð --- Phase 3: Assign codes ---
MAXCL«NU-1
CODES«(1 + NUê(2+MAXCL)) ö 0
CODES[0]«NU
ci«1

PATH«MAXCL ö 0
STACK«1000 ö 0
sp«0
STACK[sp]«ROOT
sp«sp+1
STACK[sp]«0
sp«sp+1

while (sp>0) {
  sp«sp-1
  depth«STACK[sp]
  sp«sp-1
  nd«STACK[sp]
  if (HL[nd]=1) {
    CODES[ci]«HC[nd]
    ci«ci+1
    CODES[ci]«depth
    ci«ci+1
    b«0
    while (b<depth) {
      CODES[ci]«PATH[b]
      ci«ci+1
      b«b+1
    }
  } else {
    PATH[depth]«1
    STACK[sp]«HRIGHT[nd]
    sp«sp+1
    STACK[sp]«depth+1
    sp«sp+1
    PATH[depth]«0
    STACK[sp]«HLEFT[nd]
    sp«sp+1
    STACK[sp]«depth+1
    sp«sp+1
  }
}

Ð --- Phase 4: Display codes ---
