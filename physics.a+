ă--- Self-tests ---

Ő"--- Self Tests ---
"

ăTest 1: all particles within bounds
in_boundsű1
iű0
while (i<NP) {
  radűPART[i*6+5]
  if (PART[i*6+0]-rad < 0) { in_boundsű0 }
  if (PART[i*6+0]+rad > W) { in_boundsű0 }
  if (PART[i*6+1]-rad < 0) { in_boundsű0 }
  if (PART[i*6+1]+rad > H) { in_boundsű0 }
  iűi+1
}
if (in_bounds=1) {
  Ő"physics: [PASS] All particles in bounds
"
} else {
  Ő"physics: [FAIL] Particles out of bounds
"
}

ăTest 2: no particle overlap
no_overlapű1
iű0
while (i<NP) {
  jűi+1
  while (j<NP) {
    ddűdist{i;j}
    mindűPART[i*6+5] + PART[j*6+5]
    if (dd < mind - 0.01) { no_overlapű0 }
    jűj+1
  }
  iűi+1
}
if (no_overlap=1) {
  Ő"physics: [PASS] No overlapping particles
"
} else {
  Ő"physics: [FAIL] Particles overlap
"
}

ăTest 3: energy is reasonable
if ((e1 > 0)&(e1 < e0*3)) {
  Ő"physics: [PASS] Energy reasonable
"
} else {
  Ő"physics: [FAIL] Energy unreasonable
"
}

ăTest 4: particles actually moved
any_movedű0
iű0
while (i<NP) {
  if ((PART[i*6+2] ~= 0)|(PART[i*6+3] ~= 0)) { any_movedű1 }
  iűi+1
}
if (any_moved=1) {
  Ő"physics: [PASS] Particles have velocity
"
} else {
  Ő"physics: [FAIL] No particle movement
"
}

Ő"physics: all tests done
