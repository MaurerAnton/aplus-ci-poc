í"
Koch Snowflake (3 iterations):
"
koch«lsystem{KOCH_AXIOM;KOCH_RULES;3}
koch_pts«turtle{koch;60;1}
np_koch«koch_pts[0]
í"Points: "
ínp_koch
í"
"
i«0
while (i<np_koch) {
  íkoch_pts[i*2+1]
  í" "
  íkoch_pts[i*2+2]
  í"
"
  i«i+1
}

Ð--- Sierpinski (4 iterations) ---

í"
Sierpinski Triangle (4 iterations):
"
sierp«lsystem{SIERP_AXIOM;SIERP_RULES;4}
sierp_pts«turtle{sierp;120;1}
np_sierp«sierp_pts[0]
í"Points: "
ínp_sierp
í"
"
i«0
while (i<np_sierp) {
  ísierp_pts[i*2+1]
  í" "
  ísierp_pts[i*2+2]
  í"
"
  i«i+1
}

Ð--- Self-tests ---

í"
--- Self Tests ---
"

ÐTest 1: Plant string length grows
plant_1«lsystem{PLANT_AXIOM;PLANT_RULES;1}
plant_2«lsystem{PLANT_AXIOM;PLANT_RULES;2}
len1«ö plant_1
len2«ö plant_2
if (len2 > len1) {
  í"fractal: [PASS] Plant string grows
"
} else {
  í"fractal: [FAIL] Plant string does not grow
"
}

ÐTest 2: Koch iteration check
koch_0«lsystem{KOCH_AXIOM;KOCH_RULES;0}
koch_1«lsystem{KOCH_AXIOM;KOCH_RULES;1}
koch_0_len«ö koch_0
koch_1_len«ö koch_1
if (koch_1_len > koch_0_len) {
  í"fractal: [PASS] Koch string grows
"
} else {
  í"fractal: [FAIL] Koch string does not grow
"
}

ÐTest 3: Sierpinski iteration check
sierp_1«lsystem{SIERP_AXIOM;SIERP_RULES;1}
sierp_2«lsystem{SIERP_AXIOM;SIERP_RULES;2}
s1_len«ö sierp_1
s2_len«ö sierp_2
if (s2_len > s1_len) {
  í"fractal: [PASS] Sierpinski string grows
"
} else {
  í"fractal: [FAIL] Sierpinski string does not grow
"
}

ÐTest 4: Turtle produces output for Koch
if (np_koch > 5) {
  í"fractal: [PASS] Koch turtle produces path
"
} else {
  í"fractal: [FAIL] Koch turtle path too short
"
}

ÐTest 5: Turtle produces output for Plant
if (np_plant > 5) {
  í"fractal: [PASS] Plant turtle produces path
"
} else {
  í"fractal: [FAIL] Plant turtle path too short
"
}

ÐTest 6: Sierpinski path closes (last point near first)
if (np_sierp > 3) {
  sx0«sierp_pts[1]
  sy0«sierp_pts[2]
  sxn«sierp_pts[(np_sierp-1)*2+1]
  syn«sierp_pts[(np_sierp-1)*2+2]
  sdx«sx0 - sxn
  sdy«sy0 - syn
  sdist«sqrt{sdx*sdx + sdy*sdy}
  if (sdist < 5) {
    í"fractal: [PASS] Sierpinski path closes
"
  } else {
    í"fractal: [FAIL] Sierpinski path does not close
"
  }
}

í"fractal: all tests done
"
