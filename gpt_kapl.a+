ă === Training Corpus (8 sequences, for reference) ===
ă Sequences: [0,1,2,3] [1,2,3,4] [2,3,4,5] [3,4,5,6] [4,5,6,7] [5,6,7,0] [6,7,0,1] [7,0,1,2]
ă Targets:    [1,2,3,4] [2,3,4,5] [3,4,5,6] [4,5,6,7] [5,6,7,0] [6,7,0,1] [7,0,1,2] [0,1,2,3]

ă === Forward Pass: One Transformer Block ===
ă gpt_forward tokens -> logits (seq x vocab) using stored weights
gpt_forward{tokens}: {

  ă 1. Embedding lookup + position encoding
  xembűseq dm Î 0
  posű0
  while (pos<seq) {
    idxűtokens[pos]
    jű0
    while (j<dm) {
      xemb[posÁdm+j]űE[idxÁdm+j] + P[posÁdm+j]
      jűj+1
    }
    posűpos+1
  }

  ă 2. Compute Q, K, V = xemb @ Wq, Wk, Wv
  Qűseq dm Î 0
  Kűseq dm Î 0
  Vűseq dm Î 0
  ă Q = xemb +.Á Wq using manual loops (inner product not available for all impls)
  iű0
  while (i<seq) {
    jű0
    while (j<dm) {
      sű0.0
      kű0
      while (k<dm) {
        sűs + xemb[iÁdm+k] Á Wq[kÁdm+j]
        kűk+1
      }
      Q[iÁdm+j]űs
      sű0.0
      kű0
      while (k<dm) {
        sűs + xemb[iÁdm+k] Á Wk[kÁdm+j]
        kűk+1
      }
      K[iÁdm+j]űs
      sű0.0
      kű0
      while (k<dm) {
        sűs + xemb[iÁdm+k] Á Wv[kÁdm+j]
        kűk+1
      }
      V[iÁdm+j]űs
      jűj+1
    }
    iűi+1
  }

  ă 3. Multi-head attention (4 heads, dk=2) + concatenate + project
  concatűseq dm Î 0
  hű0
  while (h<nheads) {
    hoffűhÁdk

    ă Compute attention scores for head h: scores = Q_h @ K_h^T * scale
    scoresűseq seq Î 0
    qiű0
    while (qi<seq) {
      kjű0
      while (kj<seq) {
        dotű0.0
        dű0
        while (d<dk) {
          dotűdot + Q[qiÁdm+hoff+d] Á K[kjÁdm+hoff+d]
          dűd+1
        }
        scores[qiÁseq+kj]űdot Á scale
        kjűkj+1
      }
      qiűqi+1
    }

    ă Softmax row-wise on scores -> attn_weights
    attnűseq seq Î 0
    qiű0
    while (qi<seq) {
      ă Extract row and compute softmax
      rowűseq Î 0
      kjű0
      while (kj<seq) {
        row[kj]űscores[qiÁseq+kj]
        kjűkj+1
      }
      srowűsoftmax{row;seq}
      kjű0
      while (kj<seq) {
        attn[qiÁseq+kj]űsrow[kj]
        kjűkj+1
      }
      qiűqi+1
    }

    ă Weighted sum: context_h = attn @ V_h
    ctxűseq dk Î 0
    qiű0
    while (qi<seq) {
      djű0
      while (dj<dk) {
        sű0.0
        kkű0
        while (kk<seq) {
          sűs + attn[qiÁseq+kk] Á V[kkÁdm+hoff+dj]
          kkűkk+1
        }
        ctx[qiÁdk+dj]űs
        djűdj+1
      }
      qiűqi+1
    }

    ă Place context_h into concat at head position
    qiű0
    while (qi<seq) {
      djű0
      while (dj<dk) {
        concat[qiÁdm+hoff+dj]űctx[qiÁdk+dj]
        djűdj+1
      }
      qiűqi+1
    }
    hűh+1
  }

  ă 4. Output projection: attn_out = concat @ Wo
  attn_outűseq dm Î 0
  iű0
  while (i<seq) {
    jű0
    while (j<dm) {
      sű0.0
      kű0
      while (k<dm) {
        sűs + concat[iÁdm+k] Á Wo[kÁdm+j]
        kűk+1
      }
      attn_out[iÁdm+j]űs
      jűj+1
    }
    iűi+1
  }

  ă 5. Residual connection + Layer Norm 1
  x1lnűseq dm Î 0
  iű0
  while (i<seq) {
    ă Compute mean
    mű0.0
    jű0
    while (j<dm) {
      műm + xemb[iÁdm+j] + attn_out[iÁdm+j]
      jűj+1
    }
    műmßdm
    ă Compute variance
    vű0.0
    jű0
    while (j<dm) {
      tűxemb[iÁdm+j] + attn_out[iÁdm+j] - m
      vűv + tÁt
      jűj+1
    }
    vűvßdm
    ă Normalize and scale: y = gamma*(x-mean)/(var+eps) + beta
    epsű0.00001
    jű0
    while (j<dm) {
      tűxemb[iÁdm+j] + attn_out[iÁdm+j]
      x1ln[iÁdm+j]űgamma1[j] Á (t-m) ß (v+eps) + beta1[j]
      jűj+1
    }
    iűi+1
  }

  ă 6. Feed-forward: h_ffn = sigmoid(x1ln @ W1), ffn_out = h_ffn @ W2
  hffnűseq dff Î 0
  iű0
  while (i<seq) {
    jű0
    while (j<dff) {
      sű0.0
      kű0
      while (k<dm) {
        sűs + x1ln[iÁdm+k] Á W1[kÁdff+j]
        kűk+1
      }
      ă sigmoid
      hffn[iÁdff+j]ű1ß1+*-s
      jűj+1
    }
    iűi+1
  }

  ffn_outűseq dm Î 0
  iű0
  while (i<seq) {
    jű0
    while (j<dm) {
      sű0.0
      kű0
      while (k<dff) {
        sűs + hffn[iÁdff+k] Á W2[kÁdm+j]
        kűk+1
      }
      ffn_out[iÁdm+j]űs
      jűj+1
    }
    iűi+1
  }

  ă 7. Residual connection + Layer Norm 2
  x2lnűseq dm Î 0
  iű0
  while (i<seq) {
    mű0.0
    jű0
    while (j<dm) {
      műm + x1ln[iÁdm+j] + ffn_out[iÁdm+j]
      jűj+1
    }
    műmßdm
    vű0.0
    jű0
    while (j<dm) {
      tűx1ln[iÁdm+j] + ffn_out[iÁdm+j] - m
      vűv + tÁt
      jűj+1
    }
    vűvßdm
    epsű0.00001
    jű0
    while (j<dm) {
      tűx1ln[iÁdm+j] + ffn_out[iÁdm+j]
      x2ln[iÁdm+j]űgamma2[j] Á (t-m) ß (v+eps) + beta2[j]
      jűj+1
    }
    iűi+1
  }

  ă 8. Output projection to vocab: logits = x2ln @ E^T
  logitsűseq vocab Î 0
  iű0
  while (i<seq) {
    tű0
    while (t<vocab) {
      sű0.0
      kű0
      while (k<dm) {
        sűs + x2ln[iÁdm+k] Á E[tÁdm+k]
        kűk+1
      }
      logits[iÁvocab+t]űs
      tűt+1
    }
    iűi+1
  }

  logits
}

ă === Self-Tests ===

ă Test 1: softmax integrity
tsvűsoftmax{1 2 3;3}
tssűtsv[0]+tsv[1]+tsv[2]
if ((tss>0.99)Á(tss<1.01)) { Ő"[PASS] softmax sums to ~1" } else { Ő"[FAIL] softmax" }

ă Test 2: Forward pass on prompt [0,1,2,3]
promptű4 Î 0 1 2 3
resultűgpt_forward{prompt}

ă Test 3: Verify output shape is 4x8
rshűÎ result
if (rsh[0]=4) { Ő"[PASS] output has 4 rows" } else { Ő"[FAIL] rows" }
if (rsh[1]=8) { Ő"[PASS] output has 8 cols" } else { Ő"[FAIL] cols" }

ă Test 4: Verify logits are finite (not inf/nan)
okű1
iű0
while (i<4) {
  jű0
  while (j<8) {
    vűresult[iÁ8+j]
    if (v<0-1e6) { okű0 }
    if (v>1e6) { okű0 }
    jűj+1
  }
  iűi+1
}
if (ok=1) { Ő"[PASS] logits in finite range" } else { Ő"[FAIL] logits range" }

ă Test 5: Last position (token 3) should predict token 4 as most likely
lastű4Á8
predű0-1e9
pred_idxű0
jű0
while (j<8) {
  if (result[last+j]>pred) {
    predűresult[last+j]
    pred_idxűj
  }
  jűj+1
}
Ő"Predicted next token:"
Ő pred_idx
if (pred_idx=4) {
  Ő"[PASS] GPT correctly predicts token 4 after [0,1,2,3]"
}
if (pred_idx=4) { ok_predű1 } else { ok_predű0 }
if (ok_pred=0) {
  Ő"[INFO] GPT predicts token different from expected 4"
  Ő"  (This may be OK with random initialization + limited training)"
}

ă Test 6: Softmax distribution over vocab at last position
lrowű8 Î 0
jű0
while (j<8) {
  lrow[j]űresult[last+j]
  jűj+1
}
probsűsoftmax{lrow;8}
Ő"Token probabilities (last position):"
jű0
while (j<8) {
  Ő j
  Ő probs[j]
  jűj+1
}

ă Test 7: Second prompt [7,0,1,2] -> expecting token 3
prompt2ű4 Î 7 0 1 2
result2űgpt_forward{prompt2}
last2ű3Á8
pred2ű0-1e9
pred2_idxű0
jű0
while (j<8) {
  if (result2[last2+j]>pred2) {
    pred2űresult2[last2+j]
    pred2_idxűj
  }
  jűj+1
